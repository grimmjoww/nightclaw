{
  "name": "nightclaw",
  "private": true,
  "version": "0.1.0-alpha",
  "type": "module",
  "description": "Open-source AI companion framework with 3D avatar, voice, and persistent memory. Forked from OpenClaw.",
  "author": "Willie (fps_samurai)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/grimmjoww/nightclaw"
  },
  "keywords": [
    "ai-companion",
    "ai-girlfriend",
    "ai-waifu",
    "vrm",
    "vtuber",
    "voice-assistant",
    "openclaw",
    "tauri",
    "three-js",
    "anime",
    "local-first"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "gateway": "openclaw gateway --port 18789 --verbose",
    "download:model": "python scripts/download-fish-s2.py",
    "fish:server": "cd fish-speech && python tools/api_server.py --listen 127.0.0.1:8080",
    "test": "vitest"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.4.0",
    "@pixiv/three-vrm-animation": "^3.5.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^4.3.0",
    "typescript": "~5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18"
  }
}
