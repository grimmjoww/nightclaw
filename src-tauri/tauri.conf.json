{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NightClaw",
  "version": "0.1.0",
  "identifier": "com.nightclaw.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "security": {},
    "windows": [
      {
        "label": "main",
        "title": "NightClaw",
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "width": 1920,
        "height": 1080,
        "resizable": false,
        "dragDropEnabled": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  }
}
