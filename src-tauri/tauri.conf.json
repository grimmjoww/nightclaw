{
  "$schema": "https://raw.githubusercontent.com/nicklason/tauri-schema/main/schema.json",
  "productName": "NightClaw",
  "version": "0.1.0",
  "identifier": "com.nightclaw.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "title": "NightClaw — GOD REI ◈⟡·˚✧",
    "windows": [
      {
        "label": "main",
        "title": "NightClaw — GOD REI ◈⟡·˚✧",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "transparent": false,
        "decorations": true,
        "center": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "tooltip": "NightClaw — Your companion is here ◈⟡·˚✧"
    },
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' ws://127.0.0.1:* http://127.0.0.1:* https://api.minimax.io; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  }
}
