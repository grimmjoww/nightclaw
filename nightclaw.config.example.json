{
  "_comment": "NightClaw Configuration — Edit this to customize your companion",
  "_guide": "See SETUP-FOR-AI.md for full instructions",

  "companion": {
    "name": "Your Companion's Name",
    "soulPath": "./SOUL.md",
    "pronouns": "she/her"
  },

  "llm": {
    "provider": "openclaw",
    "config": {
      "model": "anthropic/claude-sonnet-4-20250514",
      "gatewayUrl": "http://localhost:18789",
      "gatewayToken": "your-gateway-token-here",
      "temperature": 0.8
    }
  },

  "voice": {
    "enabled": false,
    "tts": {
      "provider": "disabled",
      "endpoint": "",
      "apiKey": "",
      "voiceId": "",
      "model": "s2-pro",
      "format": "mp3",
      "_comment_tts": "Supported values: disabled, fish_s2_pro, piper_http, openai_compatible_speech, custom_http_json. Fish is optional and not bundled."
    },
    "stt": {
      "provider": "none",
      "url": ""
    },
    "mode": "push-to-talk"
  },

  "avatar": {
    "modelPath": "./public/models/default.vrm",
    "modelsDirectory": "./models",
    "bringYourOwnModel": true,
    "presenceMode": "overlay",
    "environment": "nightclaw-room"
  },

  "memory": {
    "provider": "nightclaw-local",
    "autoRecall": true,
    "autoCapture": true
  },

  "discord": {
    "enabled": false,
    "token": "",
    "guildId": ""
  },

  "features": {
    "screenAwareness": true,
    "dreamJournal": false,
    "moodLighting": true,
    "visionReactions": false,
    "whisperMode": false
  }
}
